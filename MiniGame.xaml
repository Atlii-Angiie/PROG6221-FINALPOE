<Window x:Class="PROG6221_FINALPOE.MiniGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PROG6221_FINALPOE"
        mc:Ignorable="d"
               Title="CYBERBOT Quiz Game"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="LightBlue">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="AliceBlue"
                Padding="10">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <Image Source="/logo.jpg"
                       Height="70"
                       Width="100"
                       Margin="10"/>

                <!-- TITLE -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">

                    <TextBlock Text="🧠 CYBERBOT QUIZ GAME"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="DeepSkyBlue"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Test your cybersecurity knowledge"
                               FontSize="12"
                               Foreground="DarkSlateGray"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- STATUS -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <Ellipse Width="10"
                             Height="10"
                             Fill="LimeGreen"
                             Margin="0,0,5,0"/>

                    <TextBlock Text="Online"
                               Foreground="Green"
                               FontWeight="Bold"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- SCORE + PROGRESS -->
        <Border Grid.Row="1"
                Background="AliceBlue"
                Padding="10"
                Margin="0,5,0,5">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SCORE -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">

                    <TextBlock Text="🏆 Score: "
                               FontWeight="Bold"/>

                    <TextBlock x:Name="ScoreText"
                               Text="0"
                               Foreground="DeepSkyBlue"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- QUESTION NUMBER -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <TextBlock Text="📌 Question: "
                               FontWeight="Bold"/>

                    <TextBlock x:Name="QuestionNumberText"
                               Text="1/10"
                               Foreground="DeepSkyBlue"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- CORRECT / WRONG -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <TextBlock Text="✔ "
                               Foreground="Green"
                               FontWeight="Bold"/>

                    <TextBlock x:Name="CorrectCountText"
                               Text="0"
                               Foreground="Green"
                               FontWeight="Bold"
                               Margin="0,0,10,0"/>

                    <TextBlock Text="✖ "
                               Foreground="Red"
                               FontWeight="Bold"/>

                    <TextBlock x:Name="WrongCountText"
                               Text="0"
                               Foreground="Red"
                               FontWeight="Bold"/>

                </StackPanel>

            </Grid>
        </Border>

        <!-- QUESTION + ANSWERS -->
        <Border Grid.Row="2"
                Background="AliceBlue"
                Margin="10"
                Padding="20"
                BorderBrush="DeepSkyBlue"
                BorderThickness="2"
                CornerRadius="10">

            <StackPanel>

                <!-- QUESTION -->
                <TextBlock x:Name="QuestionText"
                           Text="Question appears here"
                           FontSize="18"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"
                           Foreground="Black"/>

                <!-- ANSWERS -->
                <StackPanel x:Name="AnswersPanel"/>

                <!-- FEEDBACK -->
                <TextBlock x:Name="FeedbackText"
                           Text="Select an answer to continue"
                           Margin="0,20,0,0"
                           FontStyle="Italic"
                           Foreground="Gray"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Border>

        <!-- NEXT BUTTON -->
        <Button x:Name="NextButton"
                Grid.Row="3"
                Content="Next Question →"
                Width="200"
                Height="40"
                Margin="10"
                HorizontalAlignment="Center"
                Background="DeepSkyBlue"
                Foreground="Black"
                FontWeight="Bold"
                Click="NextButton_Click"/>

    </Grid>
</Window>