<Window x:Class="PROG6221_FINALPOE.TaskManagement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PROG6221_FINALPOE"
        mc:Ignorable="d"
                Title="CYBERBOT - Task Management"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="LightBlue">

    <Grid>

        <!-- Header -->
        <Border Background="AliceBlue"
                Height="80"
                VerticalAlignment="Top">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Image Source="/logo.jpg"
                       Height="70"
                       Width="100"
                       Margin="10"/>

                <!-- Title -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">

                    <TextBlock Text="CYBERBOT TASK MANAGER"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="DeepSkyBlue"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Manage your cybersecurity awareness tasks"
                               FontSize="12"
                               Foreground="DarkSlateGray"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Status -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <Ellipse Width="10"
                             Height="10"
                             Fill="LimeGreen"
                             Margin="0,0,5,0"/>

                    <TextBlock Text="Online"
                               Foreground="Green"
                               FontWeight="Bold"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Task List -->
        <GroupBox Header="📋 My Tasks"
                  Margin="20,100,20,180"
                  FontWeight="Bold">

            <ListView x:Name="taskList"
                      FontSize="14"/>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,100">

            <Button Content="View Tasks"
                    Width="150"
                    Height="40"
                    Margin="10"
                    Background="DeepSkyBlue"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="ViewTasks_Click"/>

            <Button Content="Complete Task"
                    Width="150"
                    Height="40"
                    Margin="10"
                    Background="DeepSkyBlue"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="CompleteTask_Click"/>

            <Button Content="Delete Task"
                    Width="150"
                    Height="40"
                    Margin="10"
                    Background="DeepSkyBlue"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="DeleteTask_Click"/>
        </StackPanel>

        <!-- Activity Log -->
        <GroupBox Header="📊 Activity Log"
                  Width="300"
                  Height="150"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,20,20">

            <ListBox x:Name="activityLogDisplay"/>
        </GroupBox>

        <!-- Status Bar -->
        <Border Background="AliceBlue"
                Height="30"
                VerticalAlignment="Bottom">

            <TextBlock x:Name="statusText"
                       Text="✅ Ready to manage cybersecurity tasks"
                       FontSize="11"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
